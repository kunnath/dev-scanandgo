{
  "name": "scanandgo",
  "version": "1.2.0",
  "description": "Multi-zone bus tracking, digital ticketing & QR validation system for Kerala (Trivandrum, Kannur)",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "build": "rm -rf dist && cp -r public dist",
    "seed": "node src/seed-kannur-stops.js",
    "db:fresh-setup": "node src/scripts/fresh-setup.js --force",
    "db:enrich-routes": "node src/scripts/enrich-routes.js",
    "setup:owner-conductors": "node setup-ownerconductor-portfolio.js",
    "test": "jest --coverage"
  },
  "keywords": [
    "bus-tracking",
    "digital-tickets",
    "qr-code",
    "trivandrum",
    "kannur",
    "kerala",
    "ksrtc",
    "real-time",
    "gps",
    "multi-zone"
  ],
  "author": "ScanAndGo Team",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1041.0",
    "@aws-sdk/s3-request-presigner": "^3.1041.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^9.2.4",
    "multer": "^2.1.1",
    "node-cron": "^4.5.0",
    "nodemailer": "^8.0.5",
    "qrcode": "^1.5.4",
    "razorpay": "^2.9.6",
    "resend": "^6.12.3",
    "socket.io": "^4.7.5",
    "uuid": "^10.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
